<div class="col-md-2 text-center">
    <h4>Game History</h4>
    @foreach (var game in GamesWonHistory)
    {
        <p>Game @game.GameNumber - @game.Difficulty @game.Duration.ToString(@"mm\:ss")</p>
    }
</div>

@code {
    [Parameter] public List<GameHistoryEntry>? GamesWonHistory { get; set; }
}

<style>
    p {
        font-size: 0.8rem;
    }
</style>